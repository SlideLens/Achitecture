direction: down

# =============================================================================
# C1 — SYSTEM CONTEXT SlideLens
# =============================================================================

user: "User\n(consultant / analyst / sales)" {
  shape: person
  style.fill: "#e2e8f0"
}

slidelens: "SlideLens\nPresentation review agent\n[Software System]" {
  style.fill: "#0052cc"
  style.stroke: "#002b80"
  style.font-color: "#ffffff"
}

# --- External services ---
vlm: "Claude API (vision)\n(Slide and chart analysis)" {
  style.fill: "#f0fdf4"
  style.stroke: "#16a34a"
}
email: "Email service (SMTP)\n(Email verification, report ready)" {
  style.fill: "#fafafa"
  style.stroke: "#737373"
}
obs: "Observability\n(Sentry · Langfuse: errors, VLM traces, USD cost)\n[dev/ops plane, not runtime]" {
  style.fill: "#faf5ff"
  style.stroke: "#a855f7"
}

# --- Relationships ---
user -> slidelens: "Upload deck/pitch, read report (HTTPS)"
slidelens -> vlm: "Prompts + images / JSON (HTTPS)"
slidelens -> email: "Emails (SMTP)"
slidelens -> obs: "Errors, traces, review cost" {
  style.stroke-dash: 5
}
