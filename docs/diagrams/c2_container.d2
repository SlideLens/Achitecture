direction: down

# =============================================================================
# C2 — CONTAINERS SlideLens (VPS · Docker Compose · single Caddy domain)
# =============================================================================

user: "User (browser)" {
  shape: person
  style.fill: "#e2e8f0"
}

vps: "VPS · Docker Compose" {
  style.fill: "#f8fafc"
  style.stroke: "#94a3b8"

  caddy: "Caddy\n(HTTPS/TLS, single domain: reverse-proxy everything to app)" {
    style.fill: "#f1f5f9"
    style.stroke: "#94a3b8"
  }
  spa: "Frontend · React SPA\n(Vite + TS + Tailwind + TanStack Query;\ndist baked into image → ./static)" {
    style.fill: "#dbeafe"
    style.stroke: "#3b82f6"
  }
  api: "Backend · FastAPI\n(JSON API + JWT + limits, file upload, report delivery)" {
    style.fill: "#dbeafe"
    style.stroke: "#3b82f6"
  }
  worker: "Worker · review pipeline\n(ARQ: ingest → analysis → report, cleanup expired)" {
    style.fill: "#d1e7dd"
    style.stroke: "#0f5132"
  }

  data: "Storage" {
    style.fill: "#f8fafc"
    style.stroke: "#cbd5e1"

    db: "PostgreSQL\n(User, Review, Finding, FileAsset, Event)" {
      shape: cylinder
      style.fill: "#f5f5f5"
    }
    redis: "Redis\n(ARQ queue)" {
      shape: cylinder
      style.fill: "#f5f5f5"
    }
    files: "Files: disk → S3/R2\n(originals, PNG, reports, fixed.pptx)" {
      shape: cylinder
      style.fill: "#f5f5f5"
    }
  }

  glp: "Grafana + Loki + Prometheus\n(logs, metrics, dashboards, alerts)" {
    style.fill: "#faf5ff"
    style.stroke: "#a855f7"
  }
}

vlm: "Claude API (vision)" {
  style.fill: "#f0fdf4"
  style.stroke: "#16a34a"
}
email: "SMTP" {
  style.fill: "#fafafa"
  style.stroke: "#737373"
}

# --- Flows ---
user -> vps.caddy: "HTTPS"
vps.caddy -> vps.api: "TLS reverse-proxy, all traffic"
vps.api -> vps.spa: "serves SPA from ./static (StaticFiles)"
vps.api -> vps.data.db: "SQL"
vps.api -> vps.data.redis: "enqueue job"
vps.api -> vps.data.files: "save / serve"
vps.data.redis -> vps.worker: "review job"
vps.worker -> vlm: "vision (HTTPS)"
vps.worker -> vps.data.db: "findings, score, status"
vps.worker -> vps.data.files: "artifacts (PNG, fixed.pptx, PDF)"
vps.worker -> email: "report ready (SMTP)"
vps.api -> vps.glp: "logs, metrics" {
  style.stroke-dash: 5
}
vps.worker -> vps.glp: "logs, metrics, cost" {
  style.stroke-dash: 5
}
