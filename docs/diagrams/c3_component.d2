direction: down

# =============================================================================
# C3 — COMPONENTS: web layer (app) ↔ worker ↔ pure library (core)
# Boundary: backend/core/ does not import backend/app/ and does not touch DB (ADR 0001)
# =============================================================================

spa: "React SPA" {
  shape: person
  style.fill: "#dbeafe"
}

app: "backend/app/ — web layer (knows HTTP and DB)" {
  style.fill: "#eff6ff"
  style.stroke: "#3b82f6"

  routers: "API routers /api/v1\n(auth · reviews · findings · files · events)" {
    style.fill: "#dbeafe"
  }
  auth: "fastapi-users\n(JWT access+refresh, bcrypt)" {
    style.fill: "#dbeafe"
  }
  rev_svc: "ReviewService\n(file intake, limits, enqueue)" {
    style.fill: "#dbeafe"
  }
  services: "LimitService · Storage · EventTracker · EmailService" {
    style.fill: "#dbeafe"
  }
  orm: "SQLAlchemy 2.0 + Alembic" {
    style.fill: "#dbeafe"
  }
}

worker: "backend/worker/ — glue layer" {
  style.fill: "#f0fdf4"
  style.stroke: "#0f5132"

  task: "process_review\nworkdir → Orchestrator → DB/Storage → email" {
    style.fill: "#d1e7dd"
  }
}

core: "backend/core/ — pure library (VLM, whisper, pptx)" {
  style.fill: "#fefce8"
  style.stroke: "#ca8a04"

  orch: "PipelineOrchestrator + ReviewContext" {
    style.fill: "#fef9c3"
  }
  llm: "LLMClient\n(vision, structured output, retry, cost → Langfuse)" {
    style.fill: "#fef9c3"
  }
  ingest: "DeckIngestor · AudioExtractor · Transcriber" {
    style.fill: "#fef9c3"
  }
  analyzers: "Analyzers\n(Slide · Zoom · Deck · Chart · CrossModal)" {
    style.fill: "#fef9c3"
  }
  assemble: "Aggregator · DeckScorer · Annotator · PptxFixer · ReportBuilder" {
    style.fill: "#fef9c3"
  }
}

db: "PostgreSQL" {
  shape: cylinder
  style.fill: "#f5f5f5"
}
vlm: "Claude API (vision)" {
  style.fill: "#f0fdf4"
  style.stroke: "#16a34a"
}

# --- Relationships ---
spa -> app.routers: "REST/JSON"
app.routers -> app.auth: "JWT check"
app.routers -> app.rev_svc: "create review"
app.rev_svc -> app.services: "limit, save file, event"
app.rev_svc -> app.orm: "Review(queued)"
app.rev_svc -> worker.task: "enqueue"
worker.task -> core.orch: "run(ctx)"
core.orch -> core.ingest
core.orch -> core.analyzers
core.orch -> core.assemble
core.analyzers -> core.llm: "all VLM calls"
core.llm -> vlm: "vision (HTTPS)"
app.services -> app.orm
app.orm -> db: "SQL"
worker.task -> app.orm: "findings, score, artifacts"
