direction: down

# =============================================================================
# СХЕМА РАЗВЕРТЫВАНИЯ — VPS · Docker Compose · один домен Caddy (ADR 0004)
# =============================================================================

user: "Пользователь (браузер)" {
  shape: person
  style.fill: "#e2e8f0"
}

vps: "VPS (4 vCPU / 8 GB) — Docker Compose" {
  style.fill: "#f8fafc"
  style.stroke: "#94a3b8"

  caddy: "caddy\n(:443 HTTPS, авто-сертификат)\nTLS реверс-прокси → app" {
    style.fill: "#f1f5f9"
  }

  image: "Образ приложения (multi-stage)" {
    style.fill: "#eff6ff"
    style.stroke: "#3b82f6"

    app: "app (uvicorn)\nFastAPI: REST API + отчёт + статика SPA (./static)" {
      style.fill: "#dbeafe"
    }
    worker: "worker (arq)\nпайплайн + cron cleanup_expired_files" {
      style.fill: "#d1e7dd"
    }
    note: "внутри образа: LibreOffice, ffmpeg,\nRU-шрифты (mscorefonts, PT), faster-whisper, python-pptx" {
      style.fill: "#fefce8"
      style.stroke: "#ca8a04"
    }
  }

  db: "postgres:16 (volume)" {
    shape: cylinder
    style.fill: "#f5f5f5"
  }
  redis: "redis (очередь ARQ)" {
    shape: cylinder
    style.fill: "#f5f5f5"
  }
  files: "Файлы (volume → S3/R2)" {
    shape: cylinder
    style.fill: "#f5f5f5"
  }
  obs_stack: "grafana + loki + prometheus\n(дашборды, алерты в Telegram)" {
    style.fill: "#faf5ff"
    style.stroke: "#a855f7"
  }
  env: ".env (секреты, вне git)\nLLM_API_KEY, SMTP_*, LANGFUSE_*, SENTRY_DSN" {
    style.fill: "#fff7ed"
    style.stroke: "#ea580c"
  }
}

vlm: "Claude API (vision)" {
  style.fill: "#f0fdf4"
  style.stroke: "#16a34a"
}
smtp: "SMTP-провайдер" {
  style.fill: "#fafafa"
  style.stroke: "#737373"
}
ci: "CI/CD (push в main)\ngit pull → build → up -d → alembic upgrade" {
  style.fill: "#f1f5f9"
  style.stroke: "#94a3b8"
}

# --- Связи ---
user -> vps.caddy: "HTTPS :443"
vps.caddy -> vps.image.app: "весь трафик (HTTP)"
vps.image.app -> vps.db: "SQL"
vps.image.app -> vps.redis: "enqueue"
vps.image.app -> vps.files: "S3/FS API"
vps.redis -> vps.image.worker: "задача"
vps.image.worker -> vps.db: "SQL"
vps.image.worker -> vps.files: "артефакты"
vps.image.worker -> vlm: "HTTPS"
vps.image.worker -> smtp: "письма"
vps.env -> vps.image: "env" {style.stroke-dash: 5}
vps.image -> vps.obs_stack: "логи, метрики" {style.stroke-dash: 5}
ci -> vps: "деплой (SSH)" {style.stroke-dash: 3}
