direction: down

# =============================================================================
# DEPLOYMENT DIAGRAM — VPS · Docker Compose · single Caddy domain (ADR 0004)
# =============================================================================

user: "User (browser)" {
  shape: person
  style.fill: "#e2e8f0"
}

vps: "VPS (4 vCPU / 8 GB) — Docker Compose" {
  style.fill: "#f8fafc"
  style.stroke: "#94a3b8"

  caddy: "caddy\n(:443 HTTPS, auto certificate)\nTLS reverse-proxy → app" {
    style.fill: "#f1f5f9"
  }

  image: "Application image (multi-stage)" {
    style.fill: "#eff6ff"
    style.stroke: "#3b82f6"

    app: "app (uvicorn)\nFastAPI: REST API + report + SPA static (./static)" {
      style.fill: "#dbeafe"
    }
    worker: "worker (arq)\npipeline + cron cleanup_expired_files" {
      style.fill: "#d1e7dd"
    }
    note: "inside image: LibreOffice, ffmpeg,\nCyrillic fonts (mscorefonts, PT), faster-whisper, python-pptx" {
      style.fill: "#fefce8"
      style.stroke: "#ca8a04"
    }
  }

  db: "postgres:16 (volume)" {
    shape: cylinder
    style.fill: "#f5f5f5"
  }
  redis: "redis (ARQ queue)" {
    shape: cylinder
    style.fill: "#f5f5f5"
  }
  files: "Files (volume → S3/R2)" {
    shape: cylinder
    style.fill: "#f5f5f5"
  }
  obs_stack: "grafana + loki + prometheus\n(dashboards, Telegram alerts)" {
    style.fill: "#faf5ff"
    style.stroke: "#a855f7"
  }
  env: ".env (secrets, outside git)\nLLM_API_KEY, SMTP_*, LANGFUSE_*, SENTRY_DSN" {
    style.fill: "#fff7ed"
    style.stroke: "#ea580c"
  }
}

vlm: "Claude API (vision)" {
  style.fill: "#f0fdf4"
  style.stroke: "#16a34a"
}
smtp: "SMTP provider" {
  style.fill: "#fafafa"
  style.stroke: "#737373"
}
ci: "CI/CD (push to main)\ngit pull → build → up -d → alembic upgrade" {
  style.fill: "#f1f5f9"
  style.stroke: "#94a3b8"
}

# --- Relationships ---
user -> vps.caddy: "HTTPS :443"
vps.caddy -> vps.image.app: "all traffic (HTTP)"
vps.image.app -> vps.db: "SQL"
vps.image.app -> vps.redis: "enqueue"
vps.image.app -> vps.files: "S3/FS API"
vps.redis -> vps.image.worker: "job"
vps.image.worker -> vps.db: "SQL"
vps.image.worker -> vps.files: "artifacts"
vps.image.worker -> vlm: "HTTPS"
vps.image.worker -> smtp: "emails"
vps.env -> vps.image: "env" {style.stroke-dash: 5}
vps.image -> vps.obs_stack: "logs, metrics" {style.stroke-dash: 5}
ci -> vps: "deploy (SSH)" {style.stroke-dash: 3}
