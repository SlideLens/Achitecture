direction: down

# =============================================================================
# REVIEW PIPELINE — 10 steps (ADR 0002). Analyzer failure does not fail the review.
# =============================================================================

start: "Review: status = processing" {
  shape: oval
  style.fill: "#dbeafe"
}

s1: "1. Ingest" {
  style.fill: "#f8fafc"
  style.stroke: "#94a3b8"

  ingest: "DeckIngestor\nPPTX/PDF → PDF (LibreOffice) → PNG (pdf2image)\n+ slide texts (python-pptx)" {
    style.fill: "#e0f2fe"
  }
  transcribe: "Transcriber\naudio → WAV → faster-whisper\n→ transcript + DeliveryMetrics" {
    style.fill: "#e0f2fe"
  }
  excel: "Excel parsing (if attached)" {
    style.fill: "#e0f2fe"
  }
}

s2: "2. Analysis (VLM = Claude vision)" {
  style.fill: "#fefce8"
  style.stroke: "#ca8a04"

  slide: "SlideAnalyzer\nhierarchy, typography, readability" {
    style.fill: "#fef9c3"
  }
  zoom: "ZoomAgent\nsuspicious regions → crop ×2 → close-up" {
    style.fill: "#fef9c3"
  }
  deck: "DeckAnalyzer\nconsistency, narrative, duplicates" {
    style.fill: "#fef9c3"
  }
  chart: "ChartChecker\nclipped axes, pie≠100%, Excel check" {
    style.fill: "#fef9c3"
  }
  cross: "CrossModalAnalyzer\nspeech ↔ slides, deck recommendations" {
    style.fill: "#fef9c3"
  }
}

s3: "3. Result assembly" {
  style.fill: "#f0fdf4"
  style.stroke: "#0f5132"

  agg: "Aggregator + DeckScorer\ndedup, prioritization, score 0–100" {
    style.fill: "#d1e7dd"
  }
  annot: "Annotator (Pillow)\nbbox frames on PNG" {
    style.fill: "#d1e7dd"
  }
  fixer: "PptxFixer\ncontrast/alignment/font → fixed.pptx" {
    style.fill: "#d1e7dd"
  }
  report: "ReportBuilder + PdfExporter\nview-model + PDF (weasyprint)" {
    style.fill: "#d1e7dd"
  }
}

done: "status = done · email to user" {
  shape: oval
  style.fill: "#dcfce7"
}
fail: "status = failed + fail_reason\nfallback: attach PDF" {
  shape: oval
  style.fill: "#fee2e2"
}

# --- Flows ---
start -> s1.ingest
s1.ingest -> s2.slide
s1.ingest -> s1.transcribe: {style.stroke-dash: 4}
s1.ingest -> s1.excel: {style.stroke-dash: 4}
s2.slide -> s2.zoom
s2.zoom -> s2.deck
s2.slide -> s2.chart
s1.excel -> s2.chart: {style.stroke-dash: 4}
s1.transcribe -> s2.cross: {style.stroke-dash: 4}
s2.deck -> s3.agg
s2.chart -> s3.agg
s2.cross -> s3.agg: {style.stroke-dash: 4}
s3.agg -> s3.annot
s3.agg -> s3.fixer
s3.annot -> s3.report
s3.fixer -> s3.report
s3.report -> done
s1.ingest -> fail: "render error"
