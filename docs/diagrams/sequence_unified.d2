shape: sequence_diagram

# =============================================================================
# USER PATH: upload deck → background review → report (ADR 0003)
# =============================================================================

user: "User"
api: "FastAPI (app)"
worker: "Worker (core)"
ai: "Claude API / Whisper"
store: "DB + files"
mail: "Email (SMTP)"

# --- Registration ---
user -> api: "1. Sign up (email+password)"
api -> mail: "2. Verification email"
mail -> user: "3. Confirmation link"
user -> api: "4. Verified email, signed in (JWT)"

# --- Upload and enqueue ---
user -> api: "5. POST /reviews (deck + audio? + xlsx?) [multipart]"
api -> api: "6. Check limit (free_reviews_left) and MIME/size"
api -> store: "7. Review(status=queued), save files"
api -> user: "8. 202 — \"review started\" (cabinet)"
api -> worker: "9. Job enqueued (ARQ)"

# --- Background pipeline ---
worker -> worker: "10. Render slides to PNG (LibreOffice)"
worker -> ai: "11. Whisper — transcript with timecodes"
worker -> ai: "12. Per-slide VLM analysis + zooms"
ai -> worker: "13. Findings (JSON)"
worker -> ai: "14. Cross-slide analysis + speech ↔ slides"
ai -> worker: "15. Findings (JSON)"
worker -> worker: "16. Aggregation, scoring, annotation, autofixes → fixed.pptx"
worker -> store: "17. findings, score, artifacts, status=done"
worker -> mail: "18. \"Report ready\""
mail -> user: "19. Email with link"

# --- Read report ---
user -> api: "20. GET /reviews/{id}/report"
api -> store: "21. Build ReportOut (findings + file_assets)"
store -> api: "22. Report view-model"
api -> user: "23. Score, findings by slide, charts/delivery/speech↔slides blocks"
user -> api: "24. Download PDF / fixed.pptx"
api -> user: "25. Files (owner check)"
