shape: sequence_diagram

# =============================================================================
# ПУТЬ ПОЛЬЗОВАТЕЛЯ: загрузка деки → фоновый разбор → отчёт (ADR 0003)
# =============================================================================

user: "Пользователь"
api: "FastAPI (app)"
worker: "Воркер (core)"
ai: "Claude API / Whisper"
store: "БД + файлы"
mail: "Email (SMTP)"

# --- Регистрация ---
user -> api: "1. Регистрация (email+пароль)"
api -> mail: "2. Письмо с подтверждением"
mail -> user: "3. Ссылка подтверждения"
user -> api: "4. Подтвердил почту, вошёл (JWT)"

# --- Загрузка и постановка в очередь ---
user -> api: "5. POST /reviews (дека + аудио? + xlsx?) [multipart]"
api -> api: "6. Проверка лимита (free_reviews_left) и MIME/размера"
api -> store: "7. Review(status=queued), сохранить файлы"
api -> user: "8. 202 — «разбор запущен» (кабинет)"
api -> worker: "9. Задача в очередь (ARQ)"

# --- Фоновый пайплайн ---
worker -> worker: "10. Рендер слайдов в PNG (LibreOffice)"
worker -> ai: "11. Whisper — транскрипт с таймкодами"
worker -> ai: "12. Пер-слайдовый VLM-анализ + зумы"
ai -> worker: "13. Findings (JSON)"
worker -> ai: "14. Межслайдовый анализ + речь ↔ слайды"
ai -> worker: "15. Findings (JSON)"
worker -> worker: "16. Агрегация, скоринг, аннотация, автофиксы → fixed.pptx"
worker -> store: "17. findings, score, artifacts, status=done"
worker -> mail: "18. «Отчёт готов»"
mail -> user: "19. Письмо со ссылкой"

# --- Чтение отчёта ---
user -> api: "20. GET /reviews/{id}/report"
api -> store: "21. Собрать ReportOut (findings + file_assets)"
store -> api: "22. Вью-модель отчёта"
api -> user: "23. Скор, находки по слайдам, блоки графики/подача/речь↔слайды"
user -> api: "24. Скачать PDF / fixed.pptx"
api -> user: "25. Файлы (проверка владельца)"
